# Copy this file to .env and fill in your actual API key
# DO NOT commit .env to GitHub (it's in .gitignore)

# Your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY= "removed for commit to git"

# Model to use (keep as is, or change to gpt-4-turbo for better quality)
OPENAI_MODEL=gpt-4o-mini
